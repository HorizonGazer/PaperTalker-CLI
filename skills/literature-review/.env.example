# Literature Review Skill 环境配置
# 复制此文件为 .env 并填入您的API密钥

# Semantic Scholar API Key
# 获取地址: https://www.semanticscholar.org/product/api#api-key
# 1. 注册/登录 Semantic Scholar 账号
# 2. 点击 "Request API Key"
# 3. 填写用途说明，等待审批 (1-3天)
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# 备用变量名 (兼容 paper-search-mcp)
SS_API_KEY=your_semantic_scholar_api_key_here

# NCBI API Key (可选，用于 PubMed 搜索)
# 获取地址: https://www.ncbi.nlm.nih.gov/account/settings/ → API Key Management
# NCBI_API_KEY=your_ncbi_api_key
# NCBI_EMAIL=your_email@example.com
